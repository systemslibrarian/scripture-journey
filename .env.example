# NextAuth
NEXTAUTH_URL=https://your-app.onrender.com
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32

# Database (Render PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/scripture_journey

# Email (magic link sign-in)
# For Gmail: smtp://user:app-password@smtp.gmail.com:587
# For SendGrid: smtp://apikey:SG.xxx@smtp.sendgrid.net:587
EMAIL_SERVER=smtp://user:password@smtp.example.com:587
EMAIL_FROM=Scripture Journey <noreply@example.com>
